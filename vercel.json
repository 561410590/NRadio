{
  "rewrites": [
    {
      "source": "/",
      "destination": "/40-server-web/mayebano-support/index.html"
    },
    {
      "source": "/wechat-donate.png",
      "destination": "/40-server-web/mayebano-support/wechat-donate.png"
    },
    {
      "source": "/ssh-nradio-plugin-installer.sh",
      "destination": "/00-current/ssh-nradio-plugin-installer.sh"
    }
  ],
  "headers": [
    {
      "source": "/(.*).sh",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ]
}
