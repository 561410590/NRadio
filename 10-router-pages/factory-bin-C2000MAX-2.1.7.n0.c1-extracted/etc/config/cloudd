config cloudd 'config'
        option version '1.0'

config template 't0'
        option name 'Default'
        option diff_2_4_wlan 'X1'
        option diff_2_4_wlan_0 'X1'
        option diff_2_4_wlan_1 'X1'
        option diff_2_4_wlan_2 'X1'
        option encryption_wlan 'Xnone'
        option key_wlan 'X'
        option ssid_wlan 'XNRadio'
        option disabled_wlan 'X0'
        option disabled_wlan_0 'X1'
        option disabled_wlan_1 'X1'
        option disabled_wlan_2 'X1'
        option lowrssi_wlan 'X'
        option hidden_wlan 'X'
        option isolate_wlan 'X'
        option prb_auth_mode_wlan 'X'
        option maxstanum_wlan 'X'
        option ieee80211w_wlan 'X0'

config group 'g0'
        option action 'network'
        option dest_version '1.1.1'
        option upgrade_mode '1'
        list template 't0'
        list template 't0'

config radio 'g0radio'
        option channel_overrideradio0 'wireless.radio0.channel_override=0'
        option channel_overrideradio1 'wireless.radio1.channel_override=0'
        option channel_radio0 'wireless.radio0.channel=auto'
        option channel_radio1 'wireless.radio1.channel=auto'
        option channel_radio2 'wireless.radio2.channel=auto'

config interface 'g0wlan'
