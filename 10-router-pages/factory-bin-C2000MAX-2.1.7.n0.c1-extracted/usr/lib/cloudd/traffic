local cloudd = require "cloudd.cloudd"
local c_api = require "cloudd.api"
local cjson = require "cjson"

function cloudd_main(did, sid, event, payload, proto, reply)
	if reply == 0 then
		local lockfile = c_api.cloudd_script_lock("traffic")
		if not lockfile then
			return
		end
		c_api.cloudd_send_traffic_reply(sid, proto)
		c_api.cloudd_send_traffic_request_all_group(proto)
		c_api.cloudd_script_unlock("traffic")
		return
	end

	local p_data = cjson.decode(payload)
	local traffic = p_data["traffic"]
	local id = p_data["id"]

	if id and traffic then
		c_api.cloudd_apply_traffic_reply(id, traffic)
	end
end

c_did, c_sid, c_event, c_payload, c_proto, c_reply = cloudd.cloudd_parse_data()

cloudd_main(c_did, c_sid, c_event, c_payload, c_proto, c_reply)
