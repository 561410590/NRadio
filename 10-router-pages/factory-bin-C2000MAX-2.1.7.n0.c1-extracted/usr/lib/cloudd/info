local cloudd = require "cloudd.cloudd"
local c_api = require "cloudd.api"
local cjson = require "cjson"

function cloudd_main(did, sid, event, payload, proto, reply)
	local r_topic = "info"
	local value = {status={},stastatus={},cpestatus={},intstatus={},trafficstatus={},limitstatus={},batstatus={}}

	local data = cjson.decode(payload)   
	if reply == 1 then
		return
	end
	
	value.status = c_api.cloudd_get_status(1)
	value.wifistatus = c_api.cloudd_get_wifistatus()
	value.stastatus = c_api.cloudd_get_sta()
	value.cpestatus = c_api.cloudd_get_cpe()
	value.intstatus = c_api.cloudd_get_int()
	value.trafficstatus = c_api.cloudd_get_traffic()
	value.limitstatus = c_api.cloudd_get_limitstatus()
	value.batstatus = c_api.cloudd_get_batinfo()
	value.wanstatus = c_api.cloudd_get_wanstatus()
	value.linkstatus = c_api.cloudd_get_linkstatus()
	cloudd.cloudd_send(sid, r_topic, value, proto, 1)
end

c_did, c_sid, c_event, c_payload, c_proto, c_reply = cloudd.cloudd_parse_data()

cloudd_main(c_did, c_sid, c_event, c_payload, c_proto, c_reply)
